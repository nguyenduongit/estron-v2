{
  "expo": {
    "name": "Estron",
    "slug": "estron",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2F2F7"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Estron",
      "shortName": "Estron",
      "description": "Estron - Quản lý sản xuất",
      "backgroundColor": "#F2F2F7",
      "themeColor": "#007AFF",
      "lang": "vi"
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}